        cmd_search(args)
    elif args.command == "browse":
        cmd_browse(args)
    elif args.command == "context":
        cmd_context(args)
    elif args.command == "dedup":
        cmd_dedup(args)
    elif args.command == "ingest":
        cmd_ingest(args)
    elif args.command == "merge":
        cmd_merge(args)
