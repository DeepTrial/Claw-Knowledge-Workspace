    merge_p.add_argument("--preview", action="store_true", help="预览模式")
    
    args = parser.parse_args()
    
    if args.command == "init":
        cmd_init(args)
    elif args.command == "status":
        cmd_status(args)
    elif args.command == "rebuild":
        cmd_rebuild(args)
