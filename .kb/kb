def cmd_ingest(args):
    """入库新知识"""
    if not args.file:
        print("❌ 请提供知识文件路径")
        print("   用法: .kb/kb ingest <file.md>")
        return
    
    filepath = Path(args.file)
    if not filepath.exists():
        print(f"❌ 文件不存在: {args.file}")
        return
    
    # 提取内容
    try:
        data = extract_content(filepath)
    except Exception as e:
        print(f"❌ 解析文件失败: {e}")
        return
    
    # 检查必填字段
    if not data.get('id'):
        print("❌ 缺少必填字段: id")
        print("   请在文件开头添加 YAML frontmatter:")
        print("   ---")
        print("   id: KB-YYYYMMDD-XXX")
        print("   title: 标题")
        print("   category: 分类")
        print("   level: 1-3")
        print("   tags: [tag1, tag2]")
        print("   summary: \"摘要\"")
        print("   ---")
        return
    
    if not data.get('category') or data.get('category') == 'unknown':
        print("❌ 缺少必填字段: category")
        if args.category:
            data['category'] = args.category
            print(f"   使用命令行指定分类: {args.category}")
        else:
            return
    
    if args.level:
        data['level'] = args.level
    
    # 加载现有索引
    index = load_index()
    if not index:
        print("❌ 索引未初始化，请先运行 .kb/kb init")
        return
    
    # 去重检测
    print("🔍 去重检测...")
    
    # 1. 哈希去重
    existing = index["dedup"]["hash_index"].get(data["hash"])
    if existing:
        print(f"❌ 精确重复: 与 {existing} 内容完全相同")
        return
    
    # 2. 标签相似度
    for unit in index["units"]:
        tags1 = set(data.get('tags', []))
        tags2 = set(unit.get('tags', []))
        if tags1 and tags2:
            jaccard = len(tags1 & tags2) / len(tags1 | tags2)
            if jaccard >= 0.8:
                print(f"⚠️  标签相似度 {jaccard:.0%}: 与 {unit['id']} ({unit['title']})")
                print(f"   建议使用 .kb/kb merge {unit['id']} {data['id']} 合并")
    
    # 3. 内容相似度
    for unit in index["units"]:
        content1 = data.get('content', '')[:1000]
        content2 = ''
        unit_file = KB_ROOT / unit['file']
        if unit_file.exists():
            try:
                unit_data = extract_content(unit_file)
                content2 = unit_data.get('content', '')[:1000]
            except:
                pass
        
        if content1 and content2:
            ratio = SequenceMatcher(None, content1, content2).ratio()
            if ratio >= 0.85:
                print(f"⚠️  内容相似度 {ratio:.0%}: 与 {unit['id']} ({unit['title']})")
                print(f"   建议使用 .kb/kb merge {unit['id']} {data['id']} 合并")
    
    if args.dry_run:
        print("\n📋 预览模式（未写入）")
        print(f"   ID: {data['id']}")
        print(f"   标题: {data['title']}")
        print(f"   分类: {data['category']}")
        print(f"   等级: {data['level']}")
        print(f"   标签: {', '.join(data['tags'])}")
        print(f"   摘要: {data['summary'][:100]}...")
        return
    
    # 添加到索引
    print("\n📝 添加到索引...")
    
    # 计算新的 embedding_idx
    max_idx = max([u.get('embedding_idx', -1) for u in index['units']], default=-1)
    new_idx = max_idx + 1
    
    # 复制文件到知识库
    if filepath.parent != KB_ROOT / "TOPICS" and not str(filepath).startswith(str(KB_ROOT)):
        import shutil
        dest_dir = KB_ROOT / "TOPICS"
        dest_file = dest_dir / f"topic-{data['id'].lower()}.md"
        shutil.copy(filepath, dest_file)
        data['file'] = str(dest_file.relative_to(KB_ROOT))
        print(f"   文件已复制到: {data['file']}")
    else:
        data['file'] = str(filepath.relative_to(KB_ROOT))
    
    # 更新索引
    new_unit = {
        "id": data['id'],
        "file": data['file'],
        "title": data['title'],
        "summary": data['summary'][:200] if data['summary'] else "",
        "category": data['category'],
        "level": data['level'],
        "tags": data['tags'],
        "hash": data['hash'],
        "embedding_idx": new_idx,
        "relations": data.get('relations', {"supersedes": [], "relates": [], "cited_by": []}),
        "created": data.get('created', datetime.now().strftime('%Y-%m-%d')),
        "updated": data.get('updated', datetime.now().strftime('%Y-%m-%d'))
    }
    
    index['units'].append(new_unit)
    index['dedup']['hash_index'][data['hash']] = data['id']
    
    # 更新统计
    index['stats']['total_units'] = len(index['units'])
    category_root = data['category'].split('.')[0]
    index['stats']['by_category'][category_root] = index['stats']['by_category'].get(category_root, 0) + 1
    
    # 更新分类树
    parts = data['category'].split('.')
    for i, part in enumerate(parts):
        cat_path = '.'.join(parts[:i+1])
        if cat_path not in index['categories']:
            index['categories'][cat_path] = {
                "description": part,
                "parent": '.'.join(parts[:i]) if i > 0 else None,
                "count": 0
            }
        index['categories'][cat_path]["count"] += 1
    
    # 保存索引
    save_index(index)
    generate_auxiliary_indexes(index)
    
    print(f"\n✅ 入库成功: {data['id']}")
    print(f"   运行 .kb/kb search --id {data['id']} 查看详情")

def cmd_merge(args):
    """合并重复知识"""
    if not args.source_id or not args.target_id:
        print("❌ 请提供源 ID 和目标 ID")
        print("   用法: .kb/kb merge <source_id> <target_id>")
        print("   source_id: 将被合并的知识点（删除）")
        print("   target_id: 保留的知识点")
        return
    
    index = load_index()
    if not index:
        print("❌ 索引未初始化")
        return
    
    # 查找知识点
    source = next((u for u in index['units'] if u['id'] == args.source_id), None)
    target = next((u for u in index['units'] if u['id'] == args.target_id), None)
    
    if not source:
        print(f"❌ 未找到源知识点: {args.source_id}")
        return
    
    if not target:
        print(f"❌ 未找到目标知识点: {args.target_id}")
        return
    
    print(f"📋 合并预览:")
    print(f"   源: {source['id']} - {source['title']}")
    print(f"   目标: {target['id']} - {target['title']}")
    
    if args.preview:
        print("\n   预览模式，未执行合并")
        return
    
    # 执行合并
    print("\n🔄 执行合并...")
    
    # 1. 更新目标的关系
    if 'relations' not in target:
        target['relations'] = {"supersedes": [], "relates": [], "cited_by": []}
    
    # 添加 supersedes 关系
    if args.source_id not in target['relations']['supersedes']:
        target['relations']['supersedes'].append(args.source_id)
    
    # 合并 relates
    for rel in source.get('relations', {}).get('relates', []):
        if rel != args.target_id and rel not in target['relations']['relates']:
            target['relations']['relates'].append(rel)
    
    # 2. 更新所有引用源的知识点
    for unit in index['units']:
        if 'relations' not in unit:
            unit['relations'] = {"supersedes": [], "relates": [], "cited_by": []}
        
        # 更新 relates
        if args.source_id in unit['relations'].get('relates', []):
            unit['relations']['relates'].remove(args.source_id)
            if args.target_id not in unit['relations']['relates']:
                unit['relations']['relates'].append(args.target_id)
    
    # 3. 从索引中移除源
    index['units'] = [u for u in index['units'] if u['id'] != args.source_id]
    
    # 4. 更新哈希索引
    if source['hash'] in index['dedup']['hash_index']:
        del index['dedup']['hash_index'][source['hash']]
    
    # 5. 更新统计
    index['stats']['total_units'] = len(index['units'])
    
    # 6. 删除源文件（标记为 deprecated 或删除）
    source_file = KB_ROOT / source['file']
    if source_file.exists():
        # 创建 deprecated 标记
        deprecated_content = f"""---
id: {source['id']}
status: deprecated
superseded_by: {args.target_id}
---

# 此文档已合并到 [[{args.target_id}]]

请查看: {target['title']}
"""
        source_file.write_text(deprecated_content, encoding='utf-8')
        print(f"   源文件已标记为 deprecated: {source['file']}")
    
    # 7. 保存索引
    save_index(index)
    generate_auxiliary_indexes(index)
    
    print(f"\n✅ 合并完成")
    print(f"   保留: {target['id']} - {target['title']}")
    print(f"   废弃: {source['id']} - {source['title']}")

