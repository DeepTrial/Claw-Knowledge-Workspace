def load_config() -> dict:
    """加载配置文件"""
    if not CONFIG_FILE.exists():
        return {
            "kb": {"version": "4.0", "root": "."},
            "embedding": {"enabled": True, "model": "all-MiniLM-L6-v2"},
            "dedup": {"exact_threshold": 1.0, "tag_threshold": 0.8, "semantic_threshold": 0.90},
            "search": {"default_limit": 5, "weights": {"semantic": 0.6, "category": 0.25, "relation": 0.15}},
            "llm": {"enabled": False}
        }
    
    with open(CONFIG_FILE, 'r', encoding='utf-8') as f:
        return yaml.safe_load(f)

def save_config(config: dict):
    """保存配置文件"""
    with open(CONFIG_FILE, 'w', encoding='utf-8') as f:
        yaml.dump(config, f, default_flow_style=False, allow_unicode=True)

def load_index() -> dict:
    """加载索引文件"""
    if not INDEX_FILE.exists():
        return None
    with open(INDEX_FILE, 'r', encoding='utf-8') as f:
        return json.load(f)

def save_index(index: dict):
    """保存索引文件"""
    INDEXES_DIR.mkdir(parents=True, exist_ok=True)
    index["updated"] = datetime.now().isoformat()
    with open(INDEX_FILE, 'w', encoding='utf-8') as f:
        json.dump(index, f, ensure_ascii=False, indent=2)

def compute_hash(content: str) -> str:
    """计算内容哈希"""
    return hashlib.sha256(content.encode('utf-8')).hexdigest()[:16]

def parse_frontmatter(content: str) -> dict:
    """解析 YAML frontmatter"""
    if not content.startswith('---'):
        return {}
    
    parts = content.split('---', 2)
    if len(parts) < 3:
        return {}
    
    yaml_content = parts[1].strip()
    result = {}
    current_key = None
    current_list = []
    in_list = False
    
    for line in yaml_content.split('\n'):
        stripped = line.strip()
        if not stripped or stripped.startswith('#'):
            continue
        
        # 处理列表项
        if stripped.startswith('- '):
            if current_key and in_list:
                value = stripped[2:].strip().strip('"\'')
                current_list.append(value)
            continue
        
        # 处理键值对
        if ':' in line:
            if current_key and in_list and current_list:
                result[current_key] = current_list
                current_list = []
            
            key_part, _, value_part = line.partition(':')
            key = key_part.strip()
            value = value_part.strip()
            
            if value:
                # 处理内联列表
                if value.startswith('[') and value.endswith(']'):
                    items = value[1:-1].split(',')
                    result[key] = [item.strip().strip('"\'') for item in items if item.strip()]
                else:
                    result[key] = value.strip('"\'')
                in_list = False
            else:
                current_key = key
                current_list = []
                in_list = True
    
    # 处理最后一个列表
    if current_key and in_list and current_list:
        result[current_key] = current_list
    
    return result

def extract_content(filepath: Path) -> dict:
    """从文件提取内容和元数据"""
    content = filepath.read_text(encoding='utf-8')
    frontmatter = parse_frontmatter(content)
    
    # 提取正文（去除 frontmatter）
    body = content
    if content.startswith('---'):
        parts = content.split('---', 2)
        if len(parts) >= 3:
            body = parts[2]
    
    # 生成摘要（取前 500 字符）
    summary = frontmatter.get('summary', body.strip()[:500])
    
    return {
        'id': frontmatter.get('id'),
        'title': frontmatter.get('title', filepath.stem),
        'category': frontmatter.get('category', 'unknown'),
        'level': int(frontmatter.get('level', 2)),
        'tags': frontmatter.get('tags', []),
        'summary': summary,
        'keywords': frontmatter.get('keywords', []),
        'relations': frontmatter.get('relations', {'supersedes': [], 'relates': [], 'cited_by': []}),
        'content': body,
        'hash': compute_hash(body),
        'created': frontmatter.get('created'),
        'updated': frontmatter.get('updated')
    }

def scan_knowledge_base() -> list:
    """扫描知识库中的所有知识点"""
    units = []
    
    # 扫描 TOPICS, SKILLS, BEST_PRACTICES 目录
    for subdir in ['TOPICS', 'SKILLS', 'BEST_PRACTICES']:
        dir_path = KB_ROOT / subdir
        if not dir_path.exists():
            continue
        
        for md_file in dir_path.rglob("*.md"):
            if md_file.name in ['INDEX.md', 'README.md']:
                continue
            
            try:
                data = extract_content(md_file)
                if data.get('id'):
                    data['file'] = str(md_file.relative_to(KB_ROOT))
                    units.append(data)
            except Exception as e:
                print(f"⚠️  解析失败: {md_file.name} - {e}")
    
    return units

