def cmd_rebuild(args):
    """重建索引"""
    print("🔧 重建索引...")
    
    # 扫描知识点
    print("  📦 扫描知识点...")
    units = scan_knowledge_base()
    
    if not units:
        print("❌ 未发现任何知识点")
        return
    
    print(f"  ✅ 发现 {len(units)} 个知识点")
    
    # 构建索引
    index = {
        "version": "4.0",
        "updated": datetime.now().isoformat(),
        "config": {
            "embedding_model": "all-MiniLM-L6-v2",
            "semantic_threshold": 0.85,
            "dedup_threshold": 0.90,
            "llm_enabled": False
        },
        "stats": {
            "total_units": len(units),
            "by_category": defaultdict(int),
            "by_level": defaultdict(int)
        },
        "categories": {},
        "units": [],
        "dedup": {
            "hash_index": {},
            "similar_pairs": []
        }
    }
    
    # 处理每个知识点
    embedding_idx = 0
    for unit in units:
        # 更新分类统计
        category = unit.get('category', 'unknown')
        index["stats"]["by_category"][category.split('.')[0]] += 1
        index["stats"]["by_level"][str(unit.get('level', 2))] += 1
        
        # 更新分类树
        parts = category.split('.')
        for i, part in enumerate(parts):
            cat_path = '.'.join(parts[:i+1])
            if cat_path not in index["categories"]:
                index["categories"][cat_path] = {
                    "description": part,
                    "parent": '.'.join(parts[:i]) if i > 0 else None,
                    "count": 0
                }
            index["categories"][cat_path]["count"] += 1
        
        # 添加到哈希索引
        index["dedup"]["hash_index"][unit["hash"]] = unit["id"]
        
        # 添加到 units
        index["units"].append({
            "id": unit["id"],
            "file": unit["file"],
            "title": unit["title"],
            "summary": unit["summary"][:200] if unit["summary"] else "",
            "category": unit["category"],
            "level": unit["level"],
            "tags": unit["tags"],
            "hash": unit["hash"],
            "embedding_idx": embedding_idx,
            "relations": unit.get("relations", {"supersedes": [], "relates": [], "cited_by": []}),
            "created": unit.get("created"),
            "updated": unit.get("updated")
        })
        embedding_idx += 1
    
    # 转换 defaultdict 为 dict
    index["stats"]["by_category"] = dict(index["stats"]["by_category"])
    index["stats"]["by_level"] = dict(index["stats"]["by_level"])
    
    # 去重检测
    print("  🔍 去重检测...")
    similar_pairs = detect_similar_pairs(units)
    index["dedup"]["similar_pairs"] = similar_pairs
    print(f"  ✅ 发现 {len(similar_pairs)} 组相似知识点")
    
    # 保存索引
    save_index(index)
    print(f"  ✅ 索引已保存: {INDEX_FILE}")
    
    # 生成辅助索引
    print("  📁 生成辅助索引...")
    generate_auxiliary_indexes(index)
    
    print()
    print("✅ 索引重建完成！")
    
    # 语义向量（可选）
    if not args.no_embeddings:
        try:
            build_embeddings(units, index)
        except ImportError:
            print()
            print("⚠️  语义向量未生成（需要 sentence-transformers）")
            print("   安装: pip install sentence-transformers")

def detect_similar_pairs(units: list) -> list:
    """检测相似的知识点"""
    similar_pairs = []
    
    for i, u1 in enumerate(units):
        for u2 in units[i+1:]:
            # 标签相似度
            tags1 = set(u1.get('tags', []))
            tags2 = set(u2.get('tags', []))
            if tags1 and tags2:
                jaccard = len(tags1 & tags2) / len(tags1 | tags2)
                if jaccard >= 0.8:
                    similar_pairs.append({
                        "id1": u1["id"],
                        "id2": u2["id"],
                        "similarity": round(jaccard, 2),
                        "type": "tags",
                        "action": "suggest_merge"
                    })
                    continue
            
            # 内容相似度（简单版）
            content1 = u1.get('content', '')[:1000]
            content2 = u2.get('content', '')[:1000]
            if content1 and content2:
                ratio = SequenceMatcher(None, content1, content2).ratio()
                if ratio >= 0.85:
                    similar_pairs.append({
                        "id1": u1["id"],
                        "id2": u2["id"],
                        "similarity": round(ratio, 2),
                        "type": "content",
                        "action": "suggest_merge"
                    })
    
    return similar_pairs

def generate_auxiliary_indexes(index: dict):
    """生成辅助索引"""
    INDEXES_DIR.mkdir(parents=True, exist_ok=True)
    
    # 按领域分组
    by_domain = defaultdict(list)
    for unit in index["units"]:
        domain = unit["category"].split('.')[0]
        by_domain[domain].append({
            "id": unit["id"],
            "title": unit["title"],
            "file": unit["file"]
        })
    
    with open(INDEXES_DIR / "by-domain.json", 'w', encoding='utf-8') as f:
        json.dump(dict(by_domain), f, ensure_ascii=False, indent=2)
    
    # 按标签分组
    by_tags = defaultdict(list)
    for unit in index["units"]:
        for tag in unit.get("tags", []):
            by_tags[tag].append({
                "id": unit["id"],
                "title": unit["title"],
                "file": unit["file"]
            })
    
    with open(INDEXES_DIR / "by-tags.json", 'w', encoding='utf-8') as f:
        json.dump(dict(by_tags), f, ensure_ascii=False, indent=2)
    
    # 生成人类可读的 INDEX_TOPICS.md
    generate_human_readable_index(index)

def generate_human_readable_index(index: dict):
    """生成人类可读的知识库索引"""
    # INDEX_TOPICS.md
    topics_path = KB_ROOT / "INDEX_TOPICS.md"
    
    content = f"""# 知识库索引

> 自动生成于：{datetime.now().strftime('%Y-%m-%d %H:%M:%S')}  
> 知识点总数：{index['stats']['total_units']}

---

## 按领域分类

"""
    
    # 按领域分组
    by_domain = defaultdict(list)
    for unit in index["units"]:
        domain = unit["category"].split('.')[0]
        by_domain[domain].append(unit)
    
    for domain in sorted(by_domain.keys()):
        units = by_domain[domain]
        content += f"### {domain.upper()} ({len(units)})\n\n"
        
        for unit in sorted(units, key=lambda x: x.get('id', '')):
            content += f"- **[{unit['id']}]** {unit['title']}\n"
            content += f"  - 分类: `{unit['category']}` | 等级: {unit.get('level', '-')}\n"
            if unit.get('summary'):
                summary = unit['summary'][:80] + "..." if len(unit['summary']) > 80 else unit['summary']
                content += f"  - 摘要: {summary}\n"
            content += "\n"
    
    content += """---

## 快速检索

使用 `.kb/kb search "关键词"` 进行检索。

例如：
- `.kb/kb search "CUDA 内存"`
- `.kb/kb search "优化" --category cuda`

---

*此文件由 `.kb/kb rebuild` 自动生成，请勿手动编辑*
"""
    
    with open(topics_path, 'w', encoding='utf-8') as f:
        f.write(content)
    
    print(f"  ✅ 生成人类可读索引: {topics_path.name}")

def build_embeddings(units: list, index: dict):
    """构建语义向量"""
    try:
        from sentence_transformers import SentenceTransformer
        import numpy as np
    except ImportError:
        raise
    
    print("  🔧 生成语义向量...")
    
    model = SentenceTransformer('all-MiniLM-L6-v2')
    texts = [f"{u['title']} {u.get('summary', '')}" for u in units]
    embeddings = model.encode(texts, show_progress_bar=True)
    
    # 保存向量
    np.save(EMBEDDINGS_FILE, embeddings)
    print(f"  ✅ 语义向量已保存: {EMBEDDINGS_FILE}")
    
    # 更新索引中的向量模型信息
    index["config"]["embedding_model"] = "all-MiniLM-L6-v2"
    save_index(index)

def cmd_search(args):
    """检索知识库"""
    index = load_index()
    
    if not index:
        print("❌ 索引未初始化，请先运行 .kb/kb rebuild")
        return
    
    if args.id:
        # ID 直接获取
        unit = next((u for u in index["units"] if u["id"] == args.id), None)
        if unit:
            print(f"\n📌 {unit['id']}: {unit['title']}")
            print(f"   分类: {unit['category']}")
            print(f"   等级: {unit['level']}")
            print(f"   标签: {', '.join(unit['tags'])}")
            print(f"   文件: {unit['file']}")
            if unit.get('summary'):
                print(f"   摘要: {unit['summary'][:200]}...")
        else:
            print(f"❌ 未找到: {args.id}")
        return
    
    if not args.query:
        print("❌ 请提供查询语句或 --id")
        return
    
    # 检索
    results = search_knowledge(args.query, index, args)
    
    if not results:
        print(f"\n❌ 未找到相关知识点")
        return
    
    print(f"\n🔍 找到 {len(results)} 个结果:\n")
    for r in results:
        u = r['unit']
        print(f"📌 [{u['id']}] {u['title']}")
        print(f"   分类: {u['category']} | 等级: {u['level']}")
        print(f"   得分: {r['score']:.2f}")
        if u.get('summary'):
            print(f"   摘要: {u['summary'][:100]}...")
        print()

def search_knowledge(query: str, index: dict, args) -> list:
    """执行检索 - 支持 BM25 / 关键词 / 语义三种模式"""
    config = load_config()
    retrieval_mode = config.get("retrieval", {}).get("mode", "bm25")
    
    # 先进行分类筛选
    filtered_units = []
    for unit in index["units"]:
        if args.category and not unit["category"].startswith(args.category):
            continue
        if args.level and unit["level"] != args.level:
            continue
        filtered_units.append(unit)
    
    if not filtered_units:
        return []
    
    # 根据检索模式选择算法
    if retrieval_mode == "bm25":
        return search_bm25(query, filtered_units, args)
    elif retrieval_mode == "semantic":
        return search_semantic(query, filtered_units, index, args)
    else:
        return search_keyword(query, filtered_units, args)

def tokenize(text: str) -> list:
    """分词 - 支持中英文混合"""
    tokens = []
    # 简单分词：按空格和标点分割
    import re
    # 匹配中文字符、英文单词、数字
    pattern = r'[\u4e00-\u9fa5]+|[a-zA-Z0-9]+'
    matches = re.findall(pattern, text.lower())
    
    # 对中文进行字符级分割（简单方案）
    for m in matches:
        if re.match(r'[\u4e00-\u9fa5]+', m):
            # 中文：按字符分割（也可以按 2-gram）
            if len(m) > 1:
                # 2-gram 分词
                for i in range(len(m) - 1):
                    tokens.append(m[i:i+2])
            tokens.append(m)
        else:
            tokens.append(m)
    
    return tokens

def search_bm25(query: str, units: list, args) -> list:
    """BM25 检索"""
    try:
        from rank_bm25 import BM25Okapi
    except ImportError:
        print("⚠️  rank-bm25 未安装，降级到关键词检索")
        return search_keyword(query, units, args)
    
    # 构建文档语料库
    corpus = []
    for unit in units:
        doc = f"{unit['title']} {unit.get('summary', '')} {' '.join(unit.get('tags', []))}"
        tokens = tokenize(doc)
        corpus.append(tokens)
    
    # 构建 BM25 索引
    bm25 = BM25Okapi(corpus)
    
    # 查询
    query_tokens = tokenize(query)
    
    if not query_tokens:
        return []
    
    scores = bm25.get_scores(query_tokens)
    
    # 组合结果
    results = []
    for i, score in enumerate(scores):
        if score > 0:
            results.append({"unit": units[i], "score": float(score)})
    
    # 排序
    results.sort(key=lambda x: x["score"], reverse=True)
    
    # 限制数量
    limit = args.limit or 5
    return results[:limit]

def search_keyword(query: str, units: list, args) -> list:
    """关键词检索（降级模式）"""
    results = []
    query_lower = query.lower()
    query_words = set(query_lower.split())
    
    for unit in units:
        score = 0
        
        title_lower = unit["title"].lower()
        summary_lower = unit.get("summary", "").lower()
        tags_lower = " ".join(unit.get("tags", [])).lower()
        
        for word in query_words:
            if word in title_lower:
                score += 10
            if word in summary_lower:
                score += 5
            if word in tags_lower:
                score += 3
        
        if score > 0:
            results.append({"unit": unit, "score": float(score)})
    
    # 排序
    results.sort(key=lambda x: x["score"], reverse=True)
    
    # 限制数量
    limit = args.limit or 5
    return results[:limit]

def search_semantic(query: str, units: list, index: dict, args) -> list:
    """语义检索（需要向量索引）"""
    if not EMBEDDINGS_FILE.exists():
        print("⚠️  向量索引不存在，降级到 BM25 检索")
        return search_bm25(query, units, args)
    
    try:
        from sentence_transformers import SentenceTransformer
        import numpy as np
    except ImportError:
        print("⚠️  sentence-transformers 未安装，降级到 BM25 检索")
        return search_bm25(query, units, args)
    
    # 加载向量
    embeddings = np.load(EMBEDDINGS_FILE)
    
    # 加载模型
    config = load_config()
    model_name = config.get("embedding", {}).get("model", "all-MiniLM-L6-v2")
    model = SentenceTransformer(model_name)
    
    # 计算查询向量
    query_vector = model.encode([query])[0]
    
    # 计算相似度
    similarities = np.dot(embeddings, query_vector)
    
    # 组合结果
    results = []
    for i, unit in enumerate(units):
        if i < len(similarities) and similarities[i] > 0.3:
            results.append({"unit": unit, "score": float(similarities[i])})
    
    # 排序
    results.sort(key=lambda x: x["score"], reverse=True)
    
    # 限制数量
    limit = args.limit or 5
    return results[:limit]

