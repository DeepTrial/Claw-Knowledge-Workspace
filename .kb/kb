def main():
    parser = argparse.ArgumentParser(
        description="知识库统一管理工具 v4.0",
        formatter_class=argparse.RawDescriptionHelpFormatter
    )
    
    subparsers = parser.add_subparsers(dest="command", help="命令")
    
    # init
    subparsers.add_parser("init", help="初始化环境")
    
    # status
    subparsers.add_parser("status", help="查看状态")
    
    # rebuild
    rebuild_p = subparsers.add_parser("rebuild", help="重建索引")
    rebuild_p.add_argument("--no-embeddings", action="store_true", help="跳过向量生成")
    
    # search
    search_p = subparsers.add_parser("search", help="检索知识库")
    search_p.add_argument("query", nargs="?", help="查询语句")
    search_p.add_argument("--id", help="通过 ID 直接获取")
    search_p.add_argument("--category", help="分类筛选")
    search_p.add_argument("--level", type=int, help="等级筛选")
    search_p.add_argument("--limit", type=int, default=5, help="返回数量")
    search_p.add_argument("--llm", action="store_true", help="启用 LLM 增强")
    
    # browse
    browse_p = subparsers.add_parser("browse", help="浏览知识库")
    browse_p.add_argument("--category", help="按分类浏览")
    browse_p.add_argument("--level", type=int, help="按层级浏览")
    
    # context
    context_p = subparsers.add_parser("context", help="获取节点上下文")
    context_p.add_argument("--id", required=True, help="节点 ID")
    
    # dedup
    subparsers.add_parser("dedup", help="去重检测")
    
    # ingest
    ingest_p = subparsers.add_parser("ingest", help="入库新知识")
    ingest_p.add_argument("file", nargs="?", help="知识文件")
    ingest_p.add_argument("--category", help="指定分类")
    ingest_p.add_argument("--level", type=int, help="指定等级 (1-3)")
    ingest_p.add_argument("--dry-run", action="store_true", help="预览模式")
    
